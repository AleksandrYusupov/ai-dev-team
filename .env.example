# AI Dev Team local environment example
#
# Copy this file to `.env.local` or export the variables in your shell.
# Do not commit `.env`, `.env.local`, production URLs, webhook secrets, API
# tokens, OAuth secrets, runner bearer tokens, or private workspace paths.

# Base service settings
NODE_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=info
CONTROL_API_HOST=127.0.0.1
CONTROL_API_PORT=4000

# Internal API and runner authentication
# Generate unique local values. For example: `openssl rand -hex 32`.
INTERNAL_API_BEARER_TOKEN=replace-with-local-internal-api-token
RUNNER_AUTH_TOKENS_JSON={"local-runner":"replace-with-local-runner-token"}
RUNNER_AUTH_TOKEN=replace-with-local-runner-token

# Webhook verification secrets
# Replace these with provider-generated or locally generated webhook secrets.
LINEAR_WEBHOOK_SECRET=replace-with-local-linear-webhook-secret
GITHUB_WEBHOOK_SECRET=replace-with-local-github-webhook-secret
WEBHOOK_REPLAY_WINDOW_MS=60000
WEBHOOK_MAX_PAYLOAD_BYTES=1048576

# Knowledge/context budgets
CONTEXT_PACK_MAX_TOKENS=16000
CONTEXT_PACK_MAX_COMMENTS=10
CONTEXT_PACK_MAX_NOTES=12

# Integration metadata and broker boundaries
VENDOR_DOCS_ALLOWLIST=docs.github.com,developers.linear.app
SECRET_SERVICE_BACKEND=gcp_secret_manager
GCP_SECRET_MANAGER_PROJECT_ID=
SECRET_SERVICE_DEFAULT_PREFIX=ai-dev-team
OAUTH_PUBLIC_CALLBACK_BASE_URL=http://127.0.0.1:4000
OAUTH_REDIRECT_PATH_PREFIX=/oauth/callback
OAUTH_ENFORCE_PKCE=true
INTEGRATION_LAB_ENABLED=true
INTEGRATION_LAB_MAX_PROBE_REQUESTS=5
INTEGRATION_LAB_ALLOWED_SANDBOX_DOMAINS=api.sandbox.example.com

# Postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ai_dev_team
DB_POOL_MAX=10

# Trusted local Obsidian snapshot process
# Use a machine-local vault path. Never commit a real personal path.
KNOWLEDGE_SYNC_VAULT_ROOT=/path/to/local/obsidian/vault
KNOWLEDGE_SYNC_BATCH_SIZE=100
KNOWLEDGE_SNAPSHOT_MAX_NOTE_BYTES=131072

# Temporal
TEMPORAL_SERVER_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ai-dev-team

# Worker polling
WORKFLOW_OUTBOX_BATCH_SIZE=25
WORKFLOW_OUTBOX_POLL_INTERVAL_MS=1000
WORKFLOW_OUTBOX_MAX_ATTEMPTS=5
WORKFLOW_OUTBOX_PROCESSING_TIMEOUT_MS=30000
WORKFLOW_INGRESS_BATCH_SIZE=25
WORKFLOW_INGRESS_POLL_INTERVAL_MS=1000
WORKFLOW_INGRESS_MAX_ATTEMPTS=5

# Runner integration capability metadata
RUNNER_NETWORK_MODES_SUPPORTED=docs_allowlist,sandbox_api_allowlist
RUNNER_ALLOWED_DOC_DOMAINS=docs.github.com,developers.linear.app
RUNNER_ALLOWED_SANDBOX_DOMAINS=api.sandbox.example.com
RUNNER_SUPPORTS_BROWSER_CONSENT=false
RUNNER_SUPPORTS_SECRET_BROKER=false
RUNNER_SUPPORTS_OAUTH_BROKER=false
RUNNER_SUPPORTS_INTEGRATION_LAB=false

# Runner identity and local workspace roots
RUNNER_NODE_ID=local-runner
RUNNER_HOST_GROUP_ID=local-dev
RUNNER_POLL_BASE_URL=http://127.0.0.1:4000
RUNNER_POLL_TIMEOUT_MS=20000
RUNNER_HEARTBEAT_INTERVAL_MS=15000
RUNNER_HEARTBEAT_EXPIRY_MS=45000
RUNNER_MAX_CONCURRENT_LEASES=1
RUNNER_WORKSPACE_ROOT=/tmp/ai-dev-team-runner/workspace
RUNNER_WORKTREE_ROOT=/tmp/ai-dev-team-runner/worktrees
RUNNER_ARTIFACT_ROOT=/tmp/ai-dev-team-runner/artifacts

# Runner declared execution surface
RUNNER_PROVIDERS=codex
RUNNER_SUPPORTED_ROLES=intake_agent,spec_agent,architect_agent,plan_agent,build_agent,build_agent_backend,build_agent_integrations,test_agent,review_agent,security_agent,docs_agent,release_agent,reporter_agent,monitoring_agent,integration_agent,orchestrator
RUNNER_SUPPORTED_RUN_KINDS=build,review,deploy,rework_cycle
RUNNER_SUPPORTED_REPO_KINDS=application
RUNNER_TOOL_BASELINE=serena,sequential-thinking,obsidian,context7,github,git,filesystem,linear,postgres,fetch,memory
RUNNER_MCP_CONFIG_HASH=local-dev-mcp-config
RUNNER_MCP_HOST_SERVERS=obsidian,context7
RUNNER_MCP_REPO_SERVERS=github,filesystem,git,serena
RUNNER_MCP_EXCLUSIVE_SERVERS=sequential-thinking
RUNNER_MCP_COMMANDS_JSON={}
RUNNER_SKILL_CACHE_ROOT=/tmp/ai-dev-team-runner/managed-skills

# Optional live provider CLI commands
CODEX_CLI_BIN=codex
CLAUDE_CLI_BIN=claude
CODEX_COMMAND=
CLAUDE_CODE_COMMAND=

# Optional provider API tokens for local development only.
# Prefer OAuth/session-backed local CLIs or secret managers where possible.
LINEAR_API_TOKEN=
LINEAR_API_BASE_URL=https://api.linear.app/graphql
GITHUB_PERSONAL_ACCESS_TOKEN=

# Config publishing metadata
TOOLING_POLICY_PATH=config/agents/manifests/tooling-policy.yaml
WORKFLOW_CONFIG_PUBLISHED_BY=local-cli
