{
  "name": "ai-dev-team-control-plane",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "test": "corepack pnpm -r --if-present test",
    "test:integration": "corepack pnpm --filter @ai-dev-team/db test:integration && corepack pnpm --filter @ai-dev-team/workflow-worker test:integration && corepack pnpm --filter @ai-dev-team/control-api test:integration",
    "dev:control-api": "corepack pnpm --filter @ai-dev-team/control-api dev",
    "dev:knowledge-sync": "corepack pnpm --filter @ai-dev-team/control-api knowledge-sync",
    "dev:runner-host:codex": "corepack pnpm --filter @ai-dev-team/runner-host dev:runner-host:codex",
    "dev:runner-host:claude": "corepack pnpm --filter @ai-dev-team/runner-host dev:runner-host:claude",
    "dev:fake-runner": "corepack pnpm --filter @ai-dev-team/runner-host dev:fake-runner",
    "dev:fake-mcp": "corepack pnpm --filter @ai-dev-team/runner-host dev:fake-mcp",
    "dev:workflow-worker": "corepack pnpm --filter @ai-dev-team/workflow-worker dev",
    "dev:inbox-processor": "corepack pnpm --filter @ai-dev-team/workflow-worker dev:inbox-processor",
    "dev:outbox-executor": "corepack pnpm --filter @ai-dev-team/workflow-worker dev:outbox-executor",
    "db:migrate": "corepack pnpm --filter @ai-dev-team/db migrate",
    "db:validate-agent-config": "corepack pnpm --filter @ai-dev-team/db validate-agent-config",
    "db:validate-agent-release": "corepack pnpm --filter @ai-dev-team/db validate-agent-release",
    "db:publish-agent-release": "corepack pnpm --filter @ai-dev-team/db publish-agent-release",
    "db:publish-agent-runtime-release": "corepack pnpm --filter @ai-dev-team/db publish-agent-runtime-release",
    "db:validate-workflow-config": "corepack pnpm --filter @ai-dev-team/db validate-workflow-config",
    "db:publish-workflow-config": "corepack pnpm --filter @ai-dev-team/db publish-workflow-config",
    "test:phase6": "node scripts/phase6-test.mjs",
    "test:phase7": "node scripts/phase7-test.mjs",
    "test:phase6:live": "node scripts/phase6-live.mjs",
    "test:phase7:live": "node scripts/phase7-live.mjs",
    "smoke:phase6": "corepack pnpm --filter @ai-dev-team/runner-host smoke:phase6",
    "infra:up": "docker compose up -d postgres temporal",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs postgres temporal",
    "ci": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm test:integration && corepack pnpm test:phase6 && corepack pnpm build",
    "verify:phase6:promotion": "corepack pnpm run ci && corepack pnpm test:phase6:live",
    "verify:phase7:promotion": "corepack pnpm run ci && corepack pnpm test:phase7 && corepack pnpm test:phase7:live"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.11.12",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0"
  }
}
