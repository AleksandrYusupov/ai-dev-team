{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@ai-dev-team/shared": ["packages/shared/src/index.ts"],
      "@ai-dev-team/config": ["packages/config/src/index.ts"],
      "@ai-dev-team/db": ["packages/db/src/index.ts"]
    }
  }
}

